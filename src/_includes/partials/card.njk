{# Usage: {% for post in someCollection %}{% include "partials/card.njk" %}{% endfor %} #}
<a href="{{ post.url }}" style="display:contents;">
  <div class="card">
    <div class="card-media">
      {% if post.data.image %}<img src="{{ post.data.image }}" alt="{{ post.data.title }}" loading="lazy">{% endif %}
    </div>
    <div class="card-body">
      <div class="card-meta">
        <span class="badge badge-{{ post.data.category }}">{{ post.data.category }}</span>
        {% if post.data.score %}<span class="score-chip">{{ post.data.score }}/10</span>{% endif %}
        <span>{{ post.date | versionTag }}</span>
      </div>
      <h3>{{ post.data.title }}</h3>
      <p>{{ post.data.dek or (post.templateContent | excerpt(110)) }}</p>
    </div>
  </div>
</a>
