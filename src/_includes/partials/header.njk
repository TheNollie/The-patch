<header class="site-header">
  <div class="header-bar wrap">
    <a href="/" class="logo">
      <span>THE PATCH</span><span class="dot">.</span>
      <span class="version mono">{% year %}.1 stable</span>
    </a>
    <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="main-nav">Menu</button>
    <nav class="main-nav" id="main-nav">
      <a href="/news/" class="tag-news">News</a>
      <a href="/reviews/" class="tag-reviews">Reviews</a>
      <a href="/opinions/" class="tag-opinions">Opinions</a>
      <a href="/about/">About</a>
    </nav>
  </div>

  {% if collections.allPosts.length %}
  <div class="ticker" aria-label="Latest patch notes">
    <div class="ticker-inner">
      {% for post in collections.allPosts | limit(6) %}
      <span class="ticker-item">
        <span class="v">{{ post.date | versionTag }}</span>
        <a href="{{ post.url }}">{{ post.data.title }}</a>
      </span>
      {% endfor %}
      {% for post in collections.allPosts | limit(6) %}
      <span class="ticker-item" aria-hidden="true">
        <span class="v">{{ post.date | versionTag }}</span>
        <a href="{{ post.url }}">{{ post.data.title }}</a>
      </span>
      {% endfor %}
    </div>
  </div>
  {% endif %}
</header>
