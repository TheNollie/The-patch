---
layout: layouts/base.njk
title: null
---
<section class="hero">
  <div class="wrap">
    <div class="hero-eyebrow mono">LIVE — SHIPPING NEW PATCHES DAILY</div>
    <h1 class="hero-title">Gaming news, reviews, and hot takes — pushed daily.</h1>
    <p class="hero-sub">{{ site.description }}</p>
  </div>
</section>

{% if collections.featured.length %}
{% set feat = collections.featured[0] %}
<section class="wrap">
  <div class="featured">
    <div class="featured-media">
      {% if feat.data.image %}<img src="{{ feat.data.image }}" alt="{{ feat.data.title }}">{% endif %}
    </div>
    <div>
      <span class="badge badge-{{ feat.data.category }}">{{ feat.data.category }}</span>
      <h2><a href="{{ feat.url }}">{{ feat.data.title }}</a></h2>
      <p class="excerpt">{{ feat.data.dek or (feat.templateContent | excerpt(180)) }}</p>
      <span class="mono" style="color:var(--paper-dim); font-size:0.8rem;">{{ feat.date | versionTag }} · {{ feat.date | readableDate }}</span>
    </div>
  </div>
</section>
{% endif %}

<section class="section">
  <div class="wrap">
    <div class="section-head">
      <h2><span style="color:var(--add);">+</span> Latest News</h2>
      <a class="see-all" href="/news/">view all →</a>
    </div>
    <div class="grid">
      {% for post in collections.news | limit(3) %}
      {% include "partials/card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="wrap">
    {% include "partials/ad-slot.njk" %}
  </div>
</section>

<section class="section">
  <div class="wrap">
    <div class="section-head">
      <h2><span style="color:var(--amber);">*</span> Fresh Reviews</h2>
      <a class="see-all" href="/reviews/">view all →</a>
    </div>
    <div class="grid">
      {% for post in collections.reviews | limit(3) %}
      {% include "partials/card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>

<section class="section" style="border-bottom:none;">
  <div class="wrap">
    <div class="section-head">
      <h2><span style="color:var(--violet);">~</span> Opinions & Hot Takes</h2>
      <a class="see-all" href="/opinions/">view all →</a>
    </div>
    <div class="grid">
      {% for post in collections.opinions | limit(3) %}
      {% include "partials/card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>
