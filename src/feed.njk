---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }}</title>
  <subtitle>{{ site.description }}</subtitle>
  <link href="{{ site.url }}/feed.xml" rel="self"/>
  <link href="{{ site.url }}/"/>
  <updated>{{ collections.allPosts[0].date | htmlDateString }}T00:00:00Z</updated>
  <id>{{ site.url }}/</id>
  <author><name>{{ site.author }}</name></author>
  {% for post in collections.allPosts | limit(20) %}
  <entry>
    <title>{{ post.data.title }}</title>
    <link href="{{ site.url }}{{ post.url }}"/>
    <updated>{{ post.date | htmlDateString }}T00:00:00Z</updated>
    <id>{{ site.url }}{{ post.url }}</id>
    <summary>{{ post.data.dek or (post.templateContent | excerpt(200)) }}</summary>
  </entry>
  {% endfor %}
</feed>
