---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url><loc>{{ site.url }}/</loc></url>
  <url><loc>{{ site.url }}/news/</loc></url>
  <url><loc>{{ site.url }}/reviews/</loc></url>
  <url><loc>{{ site.url }}/opinions/</loc></url>
  <url><loc>{{ site.url }}/about/</loc></url>
  <url><loc>{{ site.url }}/contact/</loc></url>
  <url><loc>{{ site.url }}/privacy-policy/</loc></url>
  {% for post in collections.allPosts %}
  <url>
    <loc>{{ site.url }}{{ post.url }}</loc>
    <lastmod>{{ post.date | htmlDateString }}</lastmod>
  </url>
  {% endfor %}
</urlset>
