---
layout: layouts/base.njk
title: News
description: The latest gaming news, patch breakdowns, and industry updates from The Patch.
category: news
pagination:
  data: collections.news
  size: 12
  alias: posts
permalink: "/news/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber }}/{% endif %}"
---
<header class="page-header">
  <div class="wrap">
    <span class="badge badge-news">news</span>
    <h1>News</h1>
    <p style="color:var(--paper-dim);">Patch breakdowns, release dates, industry moves — as they drop.</p>
  </div>
</header>

<section class="section" style="border-bottom:none;">
  <div class="wrap">
    <div class="grid">
      {% for post in posts %}
      {% include "partials/card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>
